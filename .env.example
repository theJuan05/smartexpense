# ── Database ───────────────────────────────────────────────────
# When running with Docker, DB_HOST is overridden to "db" by docker-compose.
# For local development without Docker, use 127.0.0.1
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=smartexpense_user
DB_PASSWORD=your_strong_password_here
DB_ROOT_PASSWORD=your_root_password_here
DB_NAME=smartexpense

# ── Flask ──────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-string
JWT_SECRET_KEY=change-this-to-another-long-random-string
APP_URL=https://yourdomain.com

# ── Email (Gmail SMTP — for PIN security alerts) ───────────────
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── Brevo (transactional email — verification & password reset) ─
BREVO_API_KEY=xkeysib-your-brevo-api-key-here

# ── Google Gemini AI (receipt OCR / AI features) ──────────────
GEMINI_API_KEY=AIzaSy-your-gemini-key-here

# ── Monitoring ────────────────────────────────────────────────
GRAFANA_PASSWORD=your_grafana_password
GRAFANA_DOMAIN=yourdomain.com

# ── Firebase Cloud Messaging (push notifications) ─────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
# Paste the full JSON from Firebase Console → Project Settings → Service Accounts
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
